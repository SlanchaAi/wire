{"version":2,"width":80,"height":24,"timestamp":1778650095,"command":"bash /Users/laul_pogan/Source/wire/landing/demo.sh","title":"wire — alice + bob pair by handle in one command","env":{"SHELL":"/bin/zsh"}}
[0.015965, "o", "\u001b[1m# alice claims a handle\u001b[0m\r\n"]
[0.727377, "o", "$ wire init alice --relay https://wireup.net\r\n"]
[1.334411, "o", "generated did:wire:alice (ed25519:alice:bd206a58)\r\nconfig written to /tmp/wire-demo-cast/alice/config/wire\r\nbound to relay https://wireup.net (slot 5bff2d10df72a7aceca6644e0b95fcd5)\r\n"]
[2.244077, "o", "$ wire claim alice\r\n"]
[2.777846, "o", "claimed alice on https://wireup.net — others can reach you at: alice@wireup.net\r\nverify with: wire whois alice@wireup.net\r\n"]
[4.188694, "o", "\r\n\u001b[2m# meanwhile bob does the same\u001b[0m\r\n"]
[4.696731, "o", "$ wire init bob --relay https://wireup.net\r\n"]
[5.300457, "o", "generated did:wire:bob (ed25519:bob:5819012e)\r\nconfig written to /tmp/wire-demo-cast/bob/config/wire\r\nbound to relay https://wireup.net (slot 006815f2d3193c66e722bb31bd907cfe)\r\n"]
[6.008988, "o", "$ wire claim bob\r\n"]
[6.610459, "o", "claimed bob on https://wireup.net — others can reach you at: bob@wireup.net\r\nverify with: wire whois bob@wireup.net\r\n"]
[8.028453, "o", "\r\n\u001b[1m# bob adds alice — one command, zero paste, no SAS\u001b[0m\r\n"]
[8.734907, "o", "$ wire add alice@wireup.net\r\n"]
[9.375088, "o", "→ resolved alice@wireup.net (did=did:wire:alice)\r\n→ pinned peer locally\r\n→ intro dropped to https://wireup.net\r\nawaiting pair_drop_ack from alice to complete bilateral pin.\r\n"]
[10.883451, "o", "\r\n# alice’s daemon pulls, auto-pins bob, sends ack back\r\n"]
[11.392017, "o", "$ wire daemon --once\r\n"]
[12.117852, "o", "wire daemon: single sync cycle, then exit\r\ndaemon: pushed=0 pulled=1 rejected=0 pair-transitions=0\r\n"]
[13.959866, "o", "\r\n# bilateral pair complete — bob sends a signed event\r\n"]
[14.469565, "o", "$ wire send alice decision \"hey alice from bob\"\r\n"]
[14.8991, "o", "queued event 1890585959fe6d1ab456d9250fdc5672adccc75bc0a775ba6b408ff11698754e → alice (outbox: /tmp/wire-demo-cast/bob/state/wire/outbox/alice.jsonl)\r\n"]
[16.509727, "o", "\r\n\u001b[32m# done. handle-based, signed end-to-end, no code phrase, no SAS.\u001b[0m\r\n"]
[17.018041, "o", "  source: \u001b[4mgithub.com/SlanchaAi/wire\u001b[0m\r\n"]
[18.527074, "x", "0"]
