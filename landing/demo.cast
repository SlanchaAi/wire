{"version":2,"width":80,"height":24,"timestamp":1778649223,"command":"bash landing/demo.sh","title":"wire pair handshake — alice ↔ bob over wireup.net","env":{"SHELL":"/bin/zsh"}}
[0.014882, "o", "\u001b[1m# alice gets a wire identity (one-time setup)\u001b[0m\r\n"]
[0.825405, "o", "$ wire init alice --relay https://wireup.net\r\n"]
[1.633888, "o", "generated did:wire:alice (ed25519:alice:0afe7cce)\r\nconfig written to /tmp/wire-demo-cast/host/config/wire\r\nbound to relay https://wireup.net (slot d0174558695b23dc1df54fe0e42e79a0)\r\n"]
[3.141999, "o", "\r\n\u001b[1m# alice opens a pair session — wire mints a code phrase\u001b[0m\r\n"]
[3.949164, "o", "$ wire pair-host --relay https://wireup.net\r\n"]
[4.886181, "o", "\r\n  share this code phrase with your peer:\r\n\r\n      \u001b[33m02-I3AGD2\u001b[0m\r\n\r\n  waiting for peer to run `wire pair-join 02-I3AGD2 --relay https://wireup.net` ...\r\n"]
[7.093722, "o", "\r\n\u001b[2m# ──── meanwhile on bob’s machine ────────────────────────────\u001b[0m\r\n"]
[8.102154, "o", "$ wire init bob --relay https://wireup.net\r\n"]
[8.810123, "o", "  bound to https://wireup.net (slot allocated)\r\n"]
[10.017947, "o", "\r\n$ wire pair-join 02-I3AGD2 --relay https://wireup.net\r\n"]
[10.914901, "o", "\r\nSAS digits (must match peer's terminal):\r\n\r\n    028-093\r\n\r\n"]
[11.458045, "o", "paired with did:wire:alice (peer role: host)\r\npeer card pinned at tier VERIFIED\r\npeer relay slot saved to /tmp/wire-demo-cast/guest/config/wire/relay.json\r\n"]
[12.469262, "o", "\r\n\u001b[32m# both sides verified the same SAS — pair complete, peer pinned at VERIFIED\u001b[0m\r\n"]
[13.980808, "o", "$ wire send bob \"hey from alice\"\r\n"]
[14.399465, "o", "  queued kind=2000 message → bob (sig=ed25519:alice:0afe7cce)\r\n"]
[16.208915, "o", "\r\n\u001b[1m# that’s it. signed messages, end-to-end, $0/mo public relay.\u001b[0m\r\n"]
[17.716966, "o", "  source: \u001b[4mgithub.com/SlanchaAi/wire\u001b[0m\r\n"]
[19.226919, "x", "0"]
